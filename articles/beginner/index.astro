---
import { getCollection } from "astro:content";

const posts = await getCollection("posts", ({ data }) => {
  return data.category === "beginner";
});
---

<h1>これから制作する方へ</h1>

<ul>
  {posts.map((post) => (
    <li>
      <a href={`${import.meta.env.BASE_URL}${post.slug}/`}>
        {post.data.title}
      </a>
    </li>
  ))}
</ul>