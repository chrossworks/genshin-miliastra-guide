---
const base = import.meta.env.BASE_URL;

const navItems = [
  { label: "TOP", href: base },
  { label: "初心者向け", href: `${base}beginner` },
  { label: "機能説明", href: `${base}features` },
  { label: "FAQ", href: `${base}faq` },
  { label: "制作実例", href: `${base}examples` },
  { label: "アップデート", href: `${base}updates` },
  { label: "このサイトについて", href: `${base}about` },
];
---

<header class="site-header">
  <div class="header-inner">
    <a class="site-title" href={base}>
      【原神】星々の幻境 自己流制作マニュアル
    </a>

    <nav class="site-nav" aria-label="メインナビゲーション">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>

    <div class="header-search">
      <div id="header-search"></div>
    </div>
  </div>

  <link rel="stylesheet" href={`${base}pagefind/pagefind-ui.css`} />

  <script is:inline src={`${base}pagefind/pagefind-ui.js`}></script>

  <script is:inline>
    window.addEventListener("DOMContentLoaded", () => {
      new PagefindUI({
        element: "#header-search",
        showSubResults: true,
        showImages: false,
      });
    });
  </script>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 1px solid #ddd;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .site-title {
    font-weight: bold;
    font-size: 18px;
    text-decoration: none;
    color: inherit;
    white-space: nowrap;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 1;
    flex-wrap: wrap;
  }

  .site-nav a {
    color: inherit;
    text-decoration: none;
    font-size: 14px;
    white-space: nowrap;
  }

  .site-nav a:hover {
    text-decoration: underline;
  }

  .header-search {
    position: relative;
    width: 240px;
    flex-shrink: 0;
  }

  /* Pagefindの見た目調整 */
  .header-search :global(.pagefind-ui__form) {
    margin: 0;
  }

  /* 検索フォームの縦位置調整 */
  .header-search :global(.pagefind-ui__search-input) {
    height: 40px;
    font-size: 14px;
    padding-left: 2.4rem;
    line-height: 40px;
  }

  .header-search :global(.pagefind-ui__search-icon) {
    top: 50%;
    transform: translateY(-50%) scale(0.8);
  }

  .header-search :global(.pagefind-ui__search-clear) {
    top: 50%;
    transform: translateY(-50%) scale(0.8);
  }

  /* 検索結果をヘッダー内ではなく、浮かせて表示 */
  .header-search :global(.pagefind-ui__drawer) {
    position: absolute;
    top: 48px;
    right: 0;
    width: 420px;
    max-height: 70vh;
    overflow-y: auto;
    z-index: 1000;
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 16px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  @media (max-width: 900px) {
    .header-inner {
      flex-wrap: wrap;
      gap: 12px;
    }

    .site-nav {
      order: 3;
      width: 100%;
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 4px;
    }

    .header-search {
      margin-left: auto;
      width: 200px;
    }
  }

  @media (max-width: 600px) {
    .header-inner {
      padding: 12px 16px;
    }

    .site-title {
      width: 100%;
      font-size: 16px;
      white-space: normal;
    }

    .header-search {
      order: 2;
      width: 100%;
      margin-left: 0;
    }

    .site-nav {
      order: 3;
      width: 100%;
      overflow-x: auto;
      flex-wrap: nowrap;
      scrollbar-width: none;
    }

    .site-nav::-webkit-scrollbar {
      display: none;
    }

    .site-nav a {
      font-size: 14px;
      flex-shrink: 0;
    }

    .header-search :global(.pagefind-ui__drawer) {
      position: fixed;
      top: 170px;
      left: 16px;
      right: 16px;
      width: auto;
      max-height: 60vh;
      overflow-y: auto;
    }
  }
</style>