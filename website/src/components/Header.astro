---
const base = import.meta.env.BASE_URL;
---

<header>
  <div class="header-inner">
    <a class="site-title" href={base}>【原神】星々の幻境 自己流制作マニュアル</a>

    <nav>
      <a href={`${base}about`}>このサイトについて</a>
      <a href={`${base}about_miliastra`}>星々の幻境とは</a>
      <a href={`${base}beginner`}>これから制作する方へ</a>
<!--       <a href={`${base}features`}>機能説明</a> -->
      <div class="header-search">
        <div id="header-search"></div>
      </div>

      <link
        rel="stylesheet"
        href="/genshin-miliastra-guide/pagefind/pagefind-ui.css"
      />

      <script
        is:inline
        src="/genshin-miliastra-guide/pagefind/pagefind-ui.js"
      ></script>

      <script is:inline>
        window.addEventListener("DOMContentLoaded", () => {
          new PagefindUI({
            element: "#header-search",
            showSubResults: true,
            showImages: false,
          });
        });
      </script>
    </nav>
  </div>
</header>

<style>
  header {
    border-bottom: 1px solid #ddd;
    padding: 16px 24px;
  }

  .header-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .header-search {
    width: 240px;
  }

  .header-search :global(.pagefind-ui__form) {
    margin: 0;
  }

  .header-search :global(.pagefind-ui__search-input) {
    font-size: 0.9rem;
    padding: 0.5rem 0.75rem;
  }

  .header-search :global(.pagefind-ui__results-area) {
    position: absolute;
    z-index: 1000;
    width: 360px;
    max-height: 70vh;
    overflow-y: auto;
    background: white;
  }

  .site-title {
    display: inline-block;
    font-weight: bold;
    font-size: 20px;
    margin-bottom: 12px;
    text-decoration: none;
    color: inherit;
  }

  nav {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  nav a {
    color: inherit;
    text-decoration: none;
  }

  nav a:hover {
    text-decoration: underline;
  }
</style>