---
type BreadcrumbItem = {
  label: string;
  href?: string;
};

const { items } = Astro.props as {
  items: BreadcrumbItem[];
};

const base = import.meta.env.BASE_URL;
---

<nav class="breadcrumb" aria-label="パンくずリスト">
  <ol>
    <li>
      <a href={base}>TOP</a>
    </li>

    {items.map((item, index) => {
      const isLast = index === items.length - 1;

      return (
        <li>
          <span class="separator">/</span>
          {isLast || !item.href ? (
            <span aria-current="page">{item.label}</span>
          ) : (
            <a href={`${base}${item.href}`}>{item.label}</a>
          )}
        </li>
      );
    })}
  </ol>
</nav>

<style>
  .breadcrumb {
    max-width: 960px;
    margin: 24px auto 0;
    padding: 0 24px;
    font-size: 14px;
    color: #666;
  }

  .breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .breadcrumb li {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .separator {
    color: #aaa;
  }

  [aria-current="page"] {
    color: #333;
    font-weight: 600;
  }

  @media (max-width: 600px) {
    .breadcrumb {
      margin-top: 16px;
      padding: 0 16px;
      font-size: 13px;
    }
  }
</style>