---
import Layout from "../layouts/Layout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { getCollection, render } from "astro:content";
import Breadcrumb from "../components/Breadcrumb.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) => {
    return data.published !== false;
  });

  return articles.map((article) => {
    const slug = article.id.replace(/\/index$/, "");

    return {
      params: { slug },
      props: { article },
    };
  });
}

const { article } = Astro.props;
const { Content } = await render(article);
const SITE_NAME = "Genshin Miliastra Guide";
const pageTitle = `${article.data.title} | ${SITE_NAME}`;

const breadcrumbLabelMap = {
  about: "このサイトについて",
  about_miliastra: "星々の幻境について",

  beginner: "初心者",
  learn: "知識から学ぶ",
  build: "作りながら学ぶ",

  features: "機能説明",
  terrain: "地形制作",
  environment: "環境設定",
  entity: "エンティティの配置",
  prefab: "プレハブ制作",
  common_components: "共通コンポーネント",
  node_graph: "ノードグラフ制作",

  faq: "FAQ",
  examples: "制作実例",
  updates: "アップデート",
  columns: "コラム",
};

const slug = article.id.replace(/\/index$/, "");
const slugParts = slug.split("/");

const breadcrumbItems = slugParts.slice(0, -1).map((part, index) => {
  const href = slugParts.slice(0, index + 1).join("/");

  return {
    label: breadcrumbLabelMap[part] ?? part,
    href,
  };
});

breadcrumbItems.push({
  label: article.data.title,
});

const relatedArticles = await getCollection("articles", ({ data }) => {
  return (
    data.published !== false &&
    data.category === article.data.category
  );
});

const filteredRelatedArticles = relatedArticles.filter((relatedArticle) => {
  return relatedArticle.id !== article.id;
});
---

<Layout
  title={pageTitle}
  description={article.data.description}
>
  <main class="article-page">
    <Breadcrumb items={breadcrumbItems} />

    <Content />

    {filteredRelatedArticles.length > 0 && (
      <section class="related-articles">
        <h2>同じカテゴリの記事</h2>

        <div class="article-grid">
          {filteredRelatedArticles.map((relatedArticle) => (
            <ArticleCard article={relatedArticle} />
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>

<style>
  .article-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .related-articles {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid #ddd;
  }

  .article-grid {
    display: grid;
    gap: 1rem;
  }
</style>