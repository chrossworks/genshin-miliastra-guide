---
import Layout from "../layouts/Layout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { getCollection, render } from "astro:content";
import Breadcrumb from "../components/Breadcrumb.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) => {
    return data.published !== false;
  });

  return articles.map((article) => {
    const slug = article.id.replace(/\/index$/, "");

    return {
      params: { slug },
      props: { article },
    };
  });
}

const { article } = Astro.props;
const { Content } = await render(article);
const SITE_NAME = "Genshin Miliastra Guide";
const pageTitle = `${article.data.title} | ${SITE_NAME}`;

const relatedArticles = await getCollection("articles", ({ data }) => {
  return (
    data.published !== false &&
    data.category === article.data.category
  );
});

const filteredRelatedArticles = relatedArticles.filter((relatedArticle) => {
  return relatedArticle.id !== article.id;
});
---

<Layout
  title={pageTitle}
  description={article.data.description}
>
  <main class="article-page">
    <Breadcrumb items={article.data.breadcrumbs ?? [{ label: article.data.title }]} />

    <Content />

    {filteredRelatedArticles.length > 0 && (
      <section class="related-articles">
        <h2>同じカテゴリの記事</h2>

        <div class="article-grid">
          {filteredRelatedArticles.map((relatedArticle) => (
            <ArticleCard article={relatedArticle} />
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>

<style>
  .article-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .related-articles {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid #ddd;
  }

  .article-grid {
    display: grid;
    gap: 1rem;
  }
</style>