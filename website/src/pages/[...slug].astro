---
import Layout from "../layouts/Layout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { getCollection, render } from "astro:content";
import Breadcrumb from "../components/Breadcrumb.astro";
import { breadcrumbLabelMap, articleOrder } from "../lib/navigation";

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) => {
    return data.published !== false;
  });

  return articles.map((article) => {
    const slug = article.id.replace(/\/index$/, "");

    return {
      params: { slug },
      props: { article },
    };
  });
}

const { article } = Astro.props;
const { Content } = await render(article);
const SITE_NAME = "Genshin Miliastra Guide";
const pageTitle = `${article.data.title} | ${SITE_NAME}`;
const base = import.meta.env.BASE_URL;

const slug = article.id.replace(/\/index$/, "");
const slugParts = slug.split("/");

const breadcrumbItems = slugParts.slice(0, -1).map((part, index) => {
  const href = slugParts.slice(0, index + 1).join("/");

  return {
    label: breadcrumbLabelMap[part] ?? part,
    href,
  };
});

breadcrumbItems.push({
  label: article.data.title,
});

const relatedArticles = await getCollection("articles", ({ data }) => {
  return (
    data.published !== false &&
    data.category === article.data.category
  );
});

const filteredRelatedArticles = relatedArticles.filter((relatedArticle) => {
  return relatedArticle.id !== article.id;
});

const currentSlug = article.id.replace(/\/index$/, "");
const currentIndex = articleOrder.indexOf(currentSlug);

const prevSlug = currentIndex > 0 ? articleOrder[currentIndex - 1] : null;
const nextSlug =
  currentIndex >= 0 && currentIndex < articleOrder.length - 1
    ? articleOrder[currentIndex + 1]
    : null;

const allArticles = await getCollection("articles", ({ data }) => {
  return data.published !== false;
});

const prevArticle = prevSlug
  ? allArticles.find((item) => item.id.replace(/\/index$/, "") === prevSlug)
  : null;

const nextArticle = nextSlug
  ? allArticles.find((item) => item.id.replace(/\/index$/, "") === nextSlug)
  : null;
---

<Layout
  title={pageTitle}
  description={article.data.description}
>
  <main class="article-page">
    <Breadcrumb items={breadcrumbItems} />

    <Content />

    {(prevArticle || nextArticle) && (
      <nav class="article-nav" aria-label="前後の記事">
        <div>
          {prevArticle && (
            <a class="article-nav-card prev" href={`${base}${prevArticle.id.replace(/\/index$/, "")}`}>
              <span>前の記事</span>
              <strong>← {prevArticle.data.title}</strong>
            </a>
          )}
        </div>

        <div>
          {nextArticle && (
            <a class="article-nav-card next" href={`${base}${nextArticle.id.replace(/\/index$/, "")}`}>
              <span>次の記事</span>
              <strong>{nextArticle.data.title} →</strong>
            </a>
          )}
        </div>
      </nav>
    )}

    {filteredRelatedArticles.length > 0 && (
      <section class="related-articles">
        <h2>同じカテゴリの記事</h2>

        <div class="article-grid">
          {filteredRelatedArticles.map((relatedArticle) => (
            <ArticleCard article={relatedArticle} />
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>

<style>
  .article-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .related-articles {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid #ddd;
  }

  .article-grid {
    display: grid;
    gap: 1rem;
  }

  .article-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid #ddd;
  }

  .article-nav > div {
    min-width: 0;
  }

  .article-nav > div:last-child {
    text-align: right;
  }

  .article-nav-card {
    display: block;
    padding: 1rem;
    border: 1px solid #ddd;
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    background: #fff;
  }

  .article-nav-card:hover {
    border-color: #999;
  }

  .article-nav-card span {
    display: block;
    margin-bottom: 0.4rem;
    font-size: 0.85rem;
    color: #666;
  }

  .article-nav-card strong {
    font-size: 1rem;
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    .article-nav {
      grid-template-columns: 1fr;
    }

    .article-nav > div:last-child {
      text-align: left;
    }
  }
</style>