---
import { getEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { articleSeries } from "../../lib/navigation";

const series = articleSeries["examples"];

const articles = (
  await Promise.all(series.articles.map((slug) => getEntry("articles", slug)))
).filter((article): article is NonNullable<typeof article> => article !== undefined);
---

<Layout title="制作実例紹介">
  <main class="page-container">
    <h1>制作実例紹介</h1>
    <p>
    筆者が実際に制作した幻境の作り方の紹介等を記載していきます。<br>
    現在概要のみ記載しており、詳細別途記載予定ですので、今しばらくお待ちください。
    </p>
    <div class="article-grid">
      {articles.map((article) => (
        <ArticleCard article={article} />
      ))}
    </div>
  </main>
</Layout>

<style>
  .page-container {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .article-grid {
    display: grid;
    gap: 1rem;
  }
</style>
