---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = await getCollection("articles", ({ data }) => {
  return data.category === "beginner" && data.published === true;
});
---

<Layout title="これから制作する方へ">
  <h1>これから制作する方へ</h1>

  <ul>
    {posts.map((post) => (
      <li>
        <a href={`${import.meta.env.BASE_URL}${post.id}/`}>
          {post.data.title}
        </a>
      </li>
    ))}
  </ul>
</Layout>